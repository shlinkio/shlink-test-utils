{
    "name": "shlinkio/shlink-test-utils",
    "type": "project",
    "homepage": "https://shlink.io",
    "description": "Testing utils for Shlink",
    "license": "MIT",
    "authors": [
        {
            "name": "Alejandro Celaya Alastrué",
            "homepage": "https://www.alejandrocelaya.com",
            "email": "alejandro@alejandrocelaya.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "doctrine/data-fixtures": "^1.8",
        "doctrine/orm": "^3.5",
        "fig/http-message-util": "^1.1",
        "guzzlehttp/guzzle": "^7.9",
        "phpunit/php-code-coverage": "^13.0 || ^12.3",
        "phpunit/phpunit": "^13.0 || ^12.4",
        "psr/container": "^2.0 || ^1.0",
        "psr/http-server-middleware": "^1.0",
        "shlinkio/shlink-json": "^1.2",
        "symfony/console": "^8.0",
        "symfony/event-dispatcher": "^8.0",
        "symfony/process": "^8.0"
    },
    "require-dev": {
        "carthage-software/mago": "^1.28",
        "phpstan/phpstan": "^2.1",
        "shlinkio/shlink-mago-config": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Shlinkio\\Shlink\\TestUtils\\": "src"
        }
    },
    "scripts": {
        "ci": [
            "@cs",
            "@stan"
        ],
        "lint": "mago lint",
        "lint:fix": "mago lint --fix",
        "format": "mago format",
        "format:check": "mago format --check",
        "cs": ["@lint", "@format:check"],
        "cs:fix": ["@lint:fix", "@format"],
        "stan": "phpstan analyse"
    },
    "scripts-descriptions": {
        "ci": "<fg=blue;options=bold>Alias for \"cs\" and \"stan\"</>",
        "cs": "<fg=blue;options=bold>Checks coding styles</>",
        "cs:fix": "<fg=blue;options=bold>Fixes coding styles, when possible</>",
        "stan": "<fg=blue;options=bold>Inspects code with phpstan</>"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
